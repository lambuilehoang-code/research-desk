# Copy this file to .env and paste your key ONCE.
# Do not commit .env to GitHub.

OPENROUTER_API_KEY=sk-or-v1-paste-your-key-here
# Free (no wallet credits): openrouter/free
# Paid (needs credits): anthropic/claude-haiku-4.5 or anthropic/claude-sonnet-4.6
CLAUDE_MODEL=openrouter/free
MAX_TOKENS=2500
# Fallback only when the question is empty. Answers follow your question language (vi/en).
LANGUAGE=vi
